+-- Table des pondérations d'équité par médecin (temps partiel / ancienneté).
+-- 100 = charge cible normale (plein temps). Voir commentaire détaillé dans
+-- solver.py (classe Medecin, champ poids_equite_pct) pour la sémantique complète.
+--
+-- Clé par initiale (TEXT), cohérent avec doctor_vacations.doctor_id et
+-- doctor_equity_weekly.doctor_id : ce projet identifie les médecins par leur
+-- initiale partout, pas par UUID profiles (aucun lien profiles <-> initiale
+-- n'existe actuellement dans le code).
+
+CREATE TABLE IF NOT EXISTS public.doctor_equity_weights (
+  doctor_id TEXT PRIMARY KEY,
+  poids_equite_pct INTEGER NOT NULL DEFAULT 100 CHECK (poids_equite_pct > 0),
+  note TEXT, -- ex: "mi-temps depuis 09/2026", libre, pour se souvenir du pourquoi
+  updated_at TIMESTAMP WITH TIME ZONE DEFAULT TIMEZONE('utc', NOW())
+);
+
+ALTER TABLE public.doctor_equity_weights ENABLE ROW LEVEL SECURITY;
+
+CREATE POLICY "Authenticated users can read equity weights" ON public.doctor_equity_weights
+  FOR SELECT USING (auth.role() = 'authenticated');
+
+-- Écriture réservée aux admins (même logique que planning_notes) : on passe par
+-- le rôle applicatif vérifié côté server action, pas par une policy RLS complexe
+-- ici pour rester cohérent avec le reste du projet (voir planning-notes-actions.ts).
+CREATE POLICY "Service role can write equity weights" ON public.doctor_equity_weights
+  FOR ALL USING (auth.role() = 'service_role');
+
+-- Aucune ligne par défaut : un médecin absent de cette table est traité comme
+-- pct=100 (plein temps) côté application - voir getEquityWeights() dans
+-- app/actions/guard-api-actions.ts. Ajoutez une ligne uniquement pour les
+-- médecins dont la charge cible doit être ajustée.
